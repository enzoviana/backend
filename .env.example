# Server
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/monbackend
MONGO_LIVE=mongodb+srv://your-user:your-password@cluster.mongodb.net/

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMTP Email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@votre-domaine.fr
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@votre-domaine.fr

# Bounce Email
BOUNCEMDP=your-bounce-password
BOUNCEMAIL=bounces@votre-domaine.fr

# Stripe (pour abonnements diagnostiqueurs)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Frontend URLs
FRONTEND_DIAGNOSTIQUEUR_URL=http://localhost:8082

# Note: Pour production, remplacez les clés de test Stripe par les clés live
