# Configuration du serveur
PORT=3000

# Base de données MongoDB
MONGO_URI=mongodb://localhost:27017/monbackend
MONGO_LIVE=mongodb+srv://user:password@cluster.mongodb.net/

# JWT pour l'authentification
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# Cloudinary pour le stockage de fichiers
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Configuration SMTP pour l'envoi d'emails
SMTP_HOST=smtp.hostinger.com      # Serveur SMTP
SMTP_PORT=587                      # Port TLS/STARTTLS
SMTP_SECURE=false                  # false pour port 587
SMTP_USER=support@votre-domaine.fr # Adresse email complète
SMTP_PASS=your_password_here       # Mot de passe de l'email

# Configuration IMAP pour vérification des bounces (emails de rebond)
# Important: Utiliser les mêmes identifiants que SMTP_USER et SMTP_PASS
IMAP_HOST=imap.hostinger.com       # Serveur IMAP
IMAP_PORT=993                      # Port IMAP SSL (993 pour SSL, 143 pour STARTTLS)

# Brevo API (optionnel)
BREVO_API_KEY=your_brevo_api_key

# OpenAI API (pour génération de contenu)
OPENAI_API_KEY=your_openai_api_key

# Nom de l'expéditeur dans les emails
EMAIL_SENDER_NAME=Diagnostic Immobilier
