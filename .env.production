# ===========================================
# FICHIER DE CONFIGURATION PRODUCTION
# ===========================================
# Copiez ce fichier en .env et configurez vos valeurs réelles

# Server
NODE_ENV=production
PORT=3000

# MongoDB (utiliser la connexion Docker)
MONGO_LIVE=mongodb://mongo:27017/diag_platform

# JWT
JWT_SECRET=CHANGEZ_CE_SECRET_EN_PRODUCTION_AVEC_UNE_CLEE_LONGUE_ET_SECURISEE
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret

# SMTP Email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@votre-domaine.fr
SMTP_PASS=votre-mot-de-passe-smtp
SMTP_FROM=noreply@votre-domaine.fr

# Bounce Email
BOUNCEMDP=votre-bounce-password
BOUNCEMAIL=bounces@votre-domaine.fr

# Stripe (IMPORTANT: utilisez les clés LIVE en production!)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_1T6na2JKHW35lqjTF2MNnCQM

# Frontend URLs (adapter selon votre domaine)
FRONTEND_DIAGNOSTIQUEUR_URL=https://votre-domaine.fr

# OpenAI (si utilisé)
OPENAI_API_KEY=votre-cle-openai

# Google Calendar (si utilisé)
GOOGLE_CLIENT_ID=votre-client-id
GOOGLE_CLIENT_SECRET=votre-client-secret
GOOGLE_REDIRECT_URI=https://votre-domaine.fr/api/auth/google/callback
